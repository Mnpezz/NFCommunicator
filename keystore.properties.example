# Copy this file to ~/.config/nfccommunicator/keystore.properties
# or point NFC_COMMUNICATOR_SIGNING_PROPERTIES at another local-only path.
# Relative storeFile paths are resolved from the directory containing this file.

storeFile=keystore/nfccommunicator-release.keystore
storePassword=replace-me
keyAlias=nfccommunicator
keyPassword=replace-me
